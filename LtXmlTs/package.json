{
  "name": "ltxmlts",
  "version": "1.0.4",
  "description": "LINQ to XML for TypeScript — a port of System.Xml.Linq",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "npm run lint && tsc",
    "format": "prettier --write src",
    "lint": "eslint src",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "xml",
    "linq",
    "xpath",
    "typescript",
    "dom"
  ],
  "author": "Eric White <eric@ericwhite.com> (https://www.ericwhite.com)",
  "license": "MIT",
  "dependencies": {
    "sax": "^1.4.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/sax": "^1.2.7",
    "eslint": "^10.1.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2"
  }
}
