{
  "name": "ltxmlts",
  "version": "1.0.1",
  "description": "LINQ to XML for TypeScript — a port of System.Xml.Linq",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "keywords": ["xml", "linq", "xpath", "typescript", "dom"],
  "author": "Eric White <eric@ericwhite.com> (https://www.ericwhite.com)",
  "license": "MIT",
  "dependencies": { "sax": "^1.4.1" },
  "devDependencies": {
    "@types/sax": "^1.2.7",
    "typescript": "^5.9.3"
  }
}
